# Auto detect text files and normalize
* text=auto

# Enforce LF for Python
*.py text eol=lf

# Enforce LF for prompt templates
*.prompt text eol=lf

# Enforce LF for shell scripts
*.sh text eol=lf

# Enforce CRLF for Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Enforce LF for configs
*.toml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
.env* text eol=lf
