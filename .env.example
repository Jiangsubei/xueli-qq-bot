# ============================================
# NapCat WebSocket 配置
# ============================================
NAPCAT_WS_URL=ws://127.0.0.1:8095
NAPCAT_HTTP_URL=http://127.0.0.1:6700

# ============================================
# OpenAI 兼容服务配置（核心配置）
# ============================================
# 只需修改以下三项即可切换任意 OpenAI 兼容服务

# API 基础 URL（必须以 /v1 结尾）
# 常用服务示例：
# - OpenAI: https://api.openai.com/v1
# - DeepSeek: https://api.deepseek.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
# - 本地 Ollama: http://localhost:11434/v1
OPENAI_API_BASE=https://openrouter.ai/api/v1

# API 密钥
# 注意：某些本地服务（如 Ollama）不需要真实密钥，可填入 sk-placeholder 等占位符
OPENAI_API_KEY=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

# 模型名称
# 根据所选服务填写对应的模型名：
# - OpenAI: gpt-3.5-turbo, gpt-4, gpt-4o
# - DeepSeek: deepseek-chat, deepseek-reasoner
# - OpenRouter: stepfun/step-3.5-flash:free, anthropic/claude-3.5-sonnet
# - Ollama: llama2, mistral, qwen2.5
OPENAI_MODEL=stepfun/step-3.5-flash:free

# ============================================
# 高级配置（可选，通常保持默认即可）
# ============================================

# 额外请求参数（JSON 格式）
# 这些参数会合并到 API 请求中
# 常用参数：temperature, max_tokens, top_p, frequency_penalty, presence_penalty
OPENAI_EXTRA_PARAMS={"temperature": 0.7, "max_tokens": 2000}

# 额外请求头（JSON 格式）
# 用于添加自定义请求头
# 例如 Azure OpenAI 可能需要特定头部
OPENAI_EXTRA_HEADERS={}

# 响应内容提取路径（JSONPath 风格）
# 默认路径适用于标准 OpenAI 格式
# 如果使用的服务返回格式不同，可修改此路径
OPENAI_RESPONSE_PATH=choices.0.message.content

# ============================================
# 机器人行为配置
# ============================================
BOT_NAME=AI助手
MAX_CONTEXT_LENGTH=10
MAX_MESSAGE_LENGTH=4000
RESPONSE_TIMEOUT=60
RATE_LIMIT_INTERVAL=1.0

# ============================================
# 系统提示词
# ============================================
SYSTEM_PROMPT=你是一个友好、有帮助的AI助手。你可以回答用户的各种问题，提供有用的建议和信息。请保持回答简洁、准确，并尽可能提供有价值的内容。如果用户询问你的身份，请告诉他们你是由AI驱动的QQ机器人助手。

# ============================================
# 配置示例（复制到上面使用）
# ============================================

# --- DeepSeek 示例 ---
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=deepseek-chat

# --- OpenRouter 示例 ---
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=stepfun/step-3.5-flash:free

# --- 本地 Ollama 示例 ---
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=llama2